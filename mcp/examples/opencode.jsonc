{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadowschema": {
      "type": "local",
      "command": ["npx", "-y", "@notfixingit3/shadowschema-mcp"],
      "enabled": true,
      "timeout": 30000,
      "environment": {
        "SHADOWSCHEMA_EXPORT_URL": "http://localhost:38081"
      }
    }
  }
}