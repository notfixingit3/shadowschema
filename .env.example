# Pre-built images from GitHub Container Registry (GHCR).
# Pushes to dev publish :beta; main publishes :latest; tags publish :v1.1.0 etc.
SHADOWSCHEMA_IMAGE=ghcr.io/notfixingit3/shadowschema:beta
SHADOWSCHEMA_DASHBOARD_IMAGE=ghcr.io/notfixingit3/shadowschema-dashboard:beta

# PostgreSQL (used by docker compose stacks)
POSTGRES_USER=shadowschema
POSTGRES_PASSWORD=shadowschema
POSTGRES_DB=shadowschema

# Set on the proxy container; compose files build this automatically.
# DATABASE_URL=postgres://shadowschema:shadowschema@postgres:5432/shadowschema?sslmode=disable

# Milliseconds between spec DB writes (default 2000). Raise for heavy browsing sessions.
# SHADOWSCHEMA_SAVE_DEBOUNCE_MS=5000