# ShadowSchema Docker image tags (proxy + dashboard must match).
# See README.md "Choosing stable vs beta" for when to use each.

# Beta — tracks dev branch (default in docker-compose.yml)
SHADOWSCHEMA_IMAGE=ghcr.io/notfixingit3/shadowschema:beta
SHADOWSCHEMA_DASHBOARD_IMAGE=ghcr.io/notfixingit3/shadowschema-dashboard:beta

# Pinned stable release (recommended for production)
# SHADOWSCHEMA_IMAGE=ghcr.io/notfixingit3/shadowschema:v1.1.0
# SHADOWSCHEMA_DASHBOARD_IMAGE=ghcr.io/notfixingit3/shadowschema-dashboard:v1.1.0

# Rolling stable from main (moves on each main merge)
# SHADOWSCHEMA_IMAGE=ghcr.io/notfixingit3/shadowschema:latest
# SHADOWSCHEMA_DASHBOARD_IMAGE=ghcr.io/notfixingit3/shadowschema-dashboard:latest

# PostgreSQL (used by docker compose stacks)
POSTGRES_USER=shadowschema
POSTGRES_PASSWORD=shadowschema
POSTGRES_DB=shadowschema

# Set on the proxy container; compose files build this automatically.
# DATABASE_URL=postgres://shadowschema:shadowschema@postgres:5432/shadowschema?sslmode=disable

# Milliseconds between spec DB writes (default 2000). Raise for heavy browsing sessions.
# SHADOWSCHEMA_SAVE_DEBOUNCE_MS=5000